    "## 2.2 Promo Fatigue — Scatter: % Discount trung bình vs Volume đơn theo tháng"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Tính % discount trung bình trên 1 đơn theo tháng ─────────────────────\n",
    "# Cần biết revenue của từng item để tính % discount đúng\n",
    "# unit_price × quantity = revenue gốc trước discount\n",
    "items_all['gross_item']   = items_all['unit_price'] * order_items.reindex(items_all.index)['quantity'].fillna(1)\n",
    "# Nếu không có quantity trong items_all, dùng cột từ order_items\n",
    "items_all['quantity']     = order_items.loc[items_all.index, 'quantity'] if 'quantity' not in items_all.columns else items_all['quantity']\n",
    "items_all['gross_item']   = items_all['unit_price'] * items_all.get('quantity', 1)\n",
    "items_all['discount_pct_item'] = np.where(\n",
    "    items_all['gross_item'] > 0,\n",
    "    items_all['discount_amount'] / items_all['gross_item'] * 100,\n",
    "    0\n",
    ")\n",
    "\n",
    "# Tổng hợp lên order\n",
    "order_level = (\n",
    "    items_all\n",
    "    .groupby(['order_id', 'year'])\n",
    "    .agg(\n",
    "        total_discount = ('discount_amount', 'sum'),\n",
    "        total_gross    = ('gross_item', 'sum'),\n",
    "        period         = ('period', 'first')\n",
    "    )\n",
    "    .reset_index()\n",
    ")\n",
    "order_level['discount_pct_order'] = np.where(\n",
    "    order_level['total_gross'] > 0,\n",
    "    order_level['total_discount'] / order_level['total_gross'] * 100,\n",
    "    0\n",
    ")\n",
    "\n",
    "# Join lại year+month từ orders\n",
    "order_level = order_level.merge(\n",
    "    orders_delivered[['order_id', 'order_date']],\n",
    "    on='order_id', how='left'\n",
    ")\n",
    "order_level['ym'] = order_level['order_date'].dt.to_period('M')\n",
    "\n",
    "# Aggregate theo tháng\n",
    "monthly_promo = (\n",
    "    order_level\n",
    "    .groupby(['ym', 'period'])\n",
    "    .agg(\n",
    "        avg_discount_pct = ('discount_pct_order', 'mean'),\n",
    "        n_orders         = ('order_id', 'count')\n",
    "    )\n",
    "    .reset_index()\n",
    ")\n",
    "monthly_promo['ym_dt'] = monthly_promo['ym'].dt.to_timestamp()\n",
    "\n",
    "print(monthly_promo.head())"
   ]
  },
