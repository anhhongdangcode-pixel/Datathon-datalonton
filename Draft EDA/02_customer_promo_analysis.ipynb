    "ax.set_ylabel('Tổng số đơn hàng trong tháng', fontsize=11)\n",
    "ax.set_title('Promo Fatigue — Tương quan % Discount vs Volume đơn theo Tháng\\n'\n",
    "             'Nếu đường trend P2 dốc xuống hoặc phẳng → discount cao nhưng volume không tăng = Lờn thuốc',\n",
